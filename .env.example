# ──────────────────────────────────────────────
# 환경변수 예시 파일 (git 추적 O — 실제 값 X)
# 복사 후 .env.local 로 이름을 바꿔 사용하세요.
# cp .env.example .env.local
# ──────────────────────────────────────────────

NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=구름상회

# NEXT_PUBLIC_API_URL=
# NEXT_PUBLIC_TOSS_CLIENT_KEY=
# TOSS_SECRET_KEY=
# KMA_API_KEY=

# 관리자 인증
# ADMIN_PASSWORD=your-admin-password
# SESSION_SECRET=your-session-secret-min-32-chars  (openssl rand -hex 32)
# TENANT_ID=your-tenant-uuid  (Supabase tenants 테이블의 id — 콜드스타트 최적화)
